                mstore(add(base, 0xc0), add(mload(add(base, 0xc0)), 0xd438539c95f63e9f))
                mstore(add(base, 0xe0), add(mload(add(base, 0xe0)), 0xef781c7ce35b4c3d))
                mstore(add(base, 0x100), add(mload(add(base, 0x100)), 0xcdc4a239b0c44426))
                mstore(add(base, 0x120), add(mload(add(base, 0x120)), 0x277fa208bf337bff))
                mstore(add(base, 0x140), add(mload(add(base, 0x140)), 0xe17653a29da578a1))
                mstore(add(base, 0x160), add(mload(add(base, 0x160)), 0xc54302f225db2c76))
                mstore(base, sbox7(mload(base)))
                mstore(add(base, 0x20), sbox7(mload(add(base, 0x20))))
                mstore(add(base, 0x40), sbox7(mload(add(base, 0x40))))
                mstore(add(base, 0x60), sbox7(mload(add(base, 0x60))))
                mstore(add(base, 0x80), sbox7(mload(add(base, 0x80))))
                mstore(add(base, 0xa0), sbox7(mload(add(base, 0xa0))))
                mstore(add(base, 0xc0), sbox7(mload(add(base, 0xc0))))
                mstore(add(base, 0xe0), sbox7(mload(add(base, 0xe0))))
                mstore(add(base, 0x100), sbox7(mload(add(base, 0x100))))
                mstore(add(base, 0x120), sbox7(mload(add(base, 0x120))))
                mstore(add(base, 0x140), sbox7(mload(add(base, 0x140))))
                mstore(add(base, 0x160), sbox7(mload(add(base, 0x160))))
                mds(base)

