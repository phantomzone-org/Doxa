# Copy to services.prod.env and fill in all values before running services_start.sh.

# ── Paths ─────────────────────────────────────────────────────────────────────
RELEASE_DIR=$HOME/tessera/bin

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=api.example.com

# ── Ethereum / Sepolia ────────────────────────────────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
CHAIN_ID=11155111
BRIDGE_ADDRESS=<TESSERA_CONTRACT_ADDR>
TOKEN_ADDRESS=<USDX_CONTRACT_ADDR>
OPERATOR_KEY=<0x_OPERATOR_PRIVATE_KEY>
APPROVAL_PRIVATE_KEY=<0x_APPROVAL_PRIVATE_KEY>

# ── Sequencer ─────────────────────────────────────────────────────────────────
BIND_ADDR=127.0.0.1:3000
BATCH_TIMEOUT_SECS=10
PROVE_DELAY_SECS=10

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_CONTAINER_NAME=tessera-postgres
POSTGRES_USER=tessera
POSTGRES_PASSWORD=tessera
POSTGRES_DB=tessera
POSTGRES_PORT=5432

# ── Subpool Database APIs ─────────────────────────────────────────────────────
# Bind to localhost — nginx proxies 8081/8082/8083 → these ports over HTTPS.
DB_API_BIND_HOST=127.0.0.1
DB_API_PORT_1=9081
DB_API_PORT_2=9082
DB_API_PORT_3=9083
DATABASE_MAX_CONNECTIONS=10

# ── Subpool Operators ─────────────────────────────────────────────────────────
OPERATOR_DB_MAX_CONNECTIONS=5
POLL_INTERVAL_SECS=5
