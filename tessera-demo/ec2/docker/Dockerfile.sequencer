FROM rustlang/rust:nightly-bookworm AS builder

WORKDIR /app
COPY . .

RUN CARGO_BUILD_JOBS=2 cargo build --release -p tessera-demo

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/demo-sequencer /usr/local/bin/demo-sequencer

EXPOSE 3000
CMD ["demo-sequencer"]
