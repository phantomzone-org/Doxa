FROM rust:1.83-bookworm AS builder

WORKDIR /app
COPY . .

RUN cargo build --release -p tessera-subpool-database

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/tessera-subpool-database /usr/local/bin/tessera-subpool-database

EXPOSE 8080
CMD ["tessera-subpool-database"]
