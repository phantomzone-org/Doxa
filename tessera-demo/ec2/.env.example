# Copy this file to .env and fill in all values before deploying.
# .env is read automatically by docker compose.

# ── Image registry ────────────────────────────────────────────────────────────
# Your GitHub Container Registry path, without the image suffix.
# Images will be pushed/pulled as:
#   ${IMAGE_REGISTRY}-sequencer:${IMAGE_TAG}
#   ${IMAGE_REGISTRY}-subpool-db:${IMAGE_TAG}
#   ${IMAGE_REGISTRY}-operator:${IMAGE_TAG}
IMAGE_REGISTRY=ghcr.io/your-org/tessera
IMAGE_TAG=latest

# ── Domain ────────────────────────────────────────────────────────────────────
# The domain pointing to this EC2 instance (used by nginx + Let's Encrypt).
DOMAIN=api.example.com

# ── Ethereum / Sepolia ────────────────────────────────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
CHAIN_ID=11155111
BRIDGE_ADDRESS=<TESSERA_CONTRACT_ADDR>
TOKEN_ADDRESS=<USDX_CONTRACT_ADDR>
OPERATOR_KEY=<0x_OPERATOR_PRIVATE_KEY>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=tessera
POSTGRES_PASSWORD=tessera
POSTGRES_DB=tessera

# ── Sequencer ─────────────────────────────────────────────────────────────────
BATCH_TIMEOUT_SECS=10
PROVE_DELAY_SECS=10

# ── Subpool Database APIs ─────────────────────────────────────────────────────
DATABASE_MAX_CONNECTIONS=10

# ── Subpool Operators ─────────────────────────────────────────────────────────
APPROVAL_PRIVATE_KEY=<0x_APPROVAL_PRIVATE_KEY>
POLL_INTERVAL_SECS=5
OPERATOR_DB_MAX_CONNECTIONS=5
